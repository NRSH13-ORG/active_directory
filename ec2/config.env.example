# EC2 config — copy to config.env and customize (config.env is git-ignored)
AWS_REGION=ap-southeast-2
INSTANCE_TYPE=t3.micro
PROJECT_NAME=samba-ad-dc
KEY_NAME=samba-ad-dc
SSH_USER=ubuntu
SSH_PUBLIC_KEY_FILE=~/.ssh/id_rsa.pub
SSH_PRIVATE_KEY_PATH=~/.ssh/id_rsa
# ADMIN_SSH_CIDR=203.0.113.10/32   # auto-detected from your public IP if unset
LDAP_INGRESS_CIDR=0.0.0.0/0
